# ── Telegram ──────────────────────────────────────────────────────────────────
# Your Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat / channel ID
# Run:  curl https://api.telegram.org/bot<TOKEN>/getUpdates
# to find your chat_id after sending the bot any message.
TELEGRAM_CHAT_ID=your_chat_id_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# Model to use (gpt-4o-mini is cost-effective; use gpt-4o for higher quality)
OPENAI_MODEL=gpt-4o-mini

# ── X.com / twscrape accounts ─────────────────────────────────────────────────
# JSON array of X.com accounts used by twscrape for scraping.
# At least one account is required.  Add more to reduce rate-limit risk.
# Each object: {"username":"...", "password":"...", "email":"...", "email_password":"..."}
TWITTER_ACCOUNTS=[{"username":"your_x_username","password":"your_x_password","email":"your_email@example.com","email_password":"your_email_password"}]

# ── Scheduling ────────────────────────────────────────────────────────────────
# Time (HH:MM, UTC) to send the daily digest
DAILY_SUMMARY_TIME=09:00

# ── Scraping settings ─────────────────────────────────────────────────────────
# Max tweets to fetch per user per run
TWEETS_PER_USER=20

# Only consider posts from the past N days
LOOKBACK_DAYS=1

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file
DB_PATH=x_tracker.db
